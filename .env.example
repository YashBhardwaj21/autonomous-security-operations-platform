# Copy to .env and set real values. No production defaults are baked in.
JWT_SECRET=            # REQUIRED — auth refuses to run without it (M-5)
RESPONSE_MODE=semi     # manual | semi | full  (SOAR org policy, W1)
SOAR_CONFIDENCE_THRESHOLD=0.85
SOAR_AUTO_EXECUTE_MAX_TIER=3
UEBA_ANOMALY_THRESHOLD=0.5
